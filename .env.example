# WebSocket Manager Configuration
#
# Architecture & Secrets:
#
#   ┌─────────────────────┐  AGENT_SECRET   ┌─────────────────────┐
#   │ livekit-voice-agent │ ──────────────▶ │                     │
#   └─────────────────────┘                 │                     │
#                                           │     ws-manager      │
#   ┌─────────────────────┐  API_KEY        │                     │
#   │   OpenClaw plugin    │ ──────────────▶ │                     │
#   └─────────────────────┘                 └──────────┬──────────┘
#                                                      │
#                        ┌─────────────────────────────┴─────────────────────────────┐
#                        │                                                           │
#                        │ VALIDATE_API_KEY_SECRET               USAGE_REPORT_SECRET |
#                        ▼                                                           ▼
#              ┌─────────────────┐                                         ┌─────────────────┐
#              │ validate-api-key│                                         │  report-usage   │
#              │ (edge function) │                                         │ (edge function) │
#              └─────────────────┘                                         └─────────────────┘
#
#   Secrets summary:
#   - AGENT_SECRET: livekit-voice-agent → ws-manager (WebSocket auth)
#   - VALIDATE_API_KEY_SECRET: ws-manager → validate-api-key (validates plugin API_KEY)
#   - USAGE_REPORT_SECRET: ws-manager → report-usage (reports call duration)

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Supabase Edge Functions
SUPABASE_FUNCTIONS_URL=https://your-project-ref.supabase.co/functions/v1

# Agent authentication (shared with livekit-voice-agent)
AGENT_SECRET=shared-secret-with-livekit-agent

# Edge function authentication
VALIDATE_API_KEY_SECRET=shared-secret-with-validate-api-key-function
USAGE_REPORT_SECRET=shared-secret-with-report-usage-function

# Supabase Realtime (for plugin connection presence tracking, optional)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
